# MyOptionDiary — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains secrets

# Master encryption key for all license files
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LICENSE_SECRET=your-64-char-hex-string-here

# Gumroad product permalink (from your Gumroad product URL)
# e.g. if URL is gumroad.com/l/abcdef then permalink is abcdef
GUMROAD_PRODUCT_PERMALINK=your-gumroad-permalink-here
